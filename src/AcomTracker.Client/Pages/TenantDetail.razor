@page "/tenants/{Id:int}"
@inject AcomApiService Api
@inject NavigationManager Nav

<PageTitle>@(tenant?.Name ?? "Tenant") — AcomTracker</PageTitle>

@if (loading)
{
    <div class="loader">
        <div class="spinner"></div>
        <p class="loader-text">Loading tenant...</p>
    </div>
}
else if (pageError is not null)
{
    <div class="alert alert-danger">@pageError</div>
}
else if (tenant is not null)
{
    <div class="breadcrumb">
        <a href="/">Dashboard</a>
        <span>/</span>
        <a href="/tenants">Tenants</a>
        <span>/</span>
        <span>@tenant.Name</span>
    </div>

    <!-- Page Header -->
    <div class="page-header">
        <div style="display:flex;align-items:center;gap:16px">
            <div class="tenant-avatar" style="width:52px;height:52px;font-size:22px">
                @tenant.Name[0]
            </div>
            <div>
                <h1 class="page-title">@tenant.Name</h1>
                <p class="page-subtitle">Lease started @tenant.LeaseStartDate.ToString("MMMM d, yyyy")</p>
            </div>
        </div>
        <div style="display:flex;gap:10px;flex-wrap:wrap">
            <button class="btn btn-primary" @onclick="OpenPaymentModal">+ Record Payment</button>
            <button class="btn btn-danger-soft btn-sm" @onclick="HandleDeactivate">Deactivate</button>
        </div>
    </div>

    <!-- Balance Strip -->
    <div class="balance-strip">
        <div class="balance-card">
            <div class="balance-card-label">Total Charged</div>
            <div class="balance-card-value v-charged">€@tenant.TotalCharged.ToString("N2")</div>
            <div class="balance-card-sub">€@tenant.MonthlyRent.ToString("N0") × @MonthsActive months</div>
        </div>
        <div class="balance-card">
            <div class="balance-card-label">Total Paid</div>
            <div class="balance-card-value v-paid">€@tenant.TotalPaid.ToString("N2")</div>
            <div class="balance-card-sub">
                Last: @(tenant.LastPayment.HasValue ? tenant.LastPayment.Value.ToString("MMM d, yyyy") : "Never")
            </div>
        </div>
        <div class="balance-card">
            <div class="balance-card-label">Outstanding Balance</div>
            <div class="balance-card-value @OutstandingClass">
                @(tenant.OutstandingBalance <= 0 ? "All clear ✓" : $"€{tenant.OutstandingBalance:N2}")
            </div>
            @if (tenant.OutstandingBalance > 0 && tenant.MonthlyRent > 0)
            {
                <div class="balance-card-sub" style="color:var(--danger)">
                    ≈ @Math.Round(tenant.OutstandingBalance / tenant.MonthlyRent, 1) months behind
                </div>
            }
        </div>
    </div>

    <!-- Lease Info -->
    <div class="card" style="margin-bottom:20px">
        <div class="card-header">
            <span class="card-title">Lease Details</span>
        </div>
        <div class="card-body">
            <div class="info-grid">
                <div>
                    <div class="info-label">Monthly Rent</div>
                    <div class="info-value">€@tenant.MonthlyRent.ToString("N2")</div>
                </div>
                <div>
                    <div class="info-label">Lease Start</div>
                    <div class="info-value">@tenant.LeaseStartDate.ToString("MMMM d, yyyy")</div>
                </div>
                <div>
                    <div class="info-label">Months Active</div>
                    <div class="info-value">@MonthsActive months</div>
                </div>
                <div>
                    <div class="info-label">Last Payment</div>
                    <div class="info-value">
                        @(tenant.LastPayment.HasValue ? tenant.LastPayment.Value.ToString("MMM d, yyyy") : "—")
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Payment History -->
    <div class="card">
        <div class="card-header">
            <span class="card-title">Payment History</span>
            <span class="badge badge-neutral">@(payments?.Length ?? 0) payments</span>
        </div>
        <div class="card-body">
            @if (paymentsLoading)
            {
                <div class="loader" style="padding:40px">
                    <div class="spinner"></div>
                </div>
            }
            else if (payments is null || payments.Length == 0)
            {
                <div class="empty-state">
                    <div class="empty-state-icon">💳</div>
                    <div class="empty-state-title">No payments recorded</div>
                    <div class="empty-state-desc">Use the button above to record the first payment</div>
                </div>
            }
            else
            {
                <div class="payment-list">
                    @foreach (var p in payments)
                    {
                        <div class="payment-row">
                            <div class="payment-date">@p.Date.ToString("MMM d, yyyy")</div>
                            <span class="badge badge-info">@p.Method</span>
                            <span class="payment-notes">@(p.Notes ?? "")</span>
                            <div class="payment-amount">+€@p.Amount.ToString("N2")</div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
}

<!-- Add Payment Modal -->
@if (showModal)
{
    <div class="modal-overlay" @onclick="CloseModal">
        <div class="modal" @onclick:stopPropagation>
            <div class="modal-header">
                <span class="modal-title">Record Payment</span>
                <button class="modal-close" @onclick="CloseModal">×</button>
            </div>
            <div class="modal-body">
                @if (modalError is not null)
                {
                    <div class="alert alert-danger">@modalError</div>
                }
                <div class="form-group">
                    <label class="form-label">Amount (€)</label>
                    <input class="form-control"
                           type="number"
                           step="0.01"
                           min="0.01"
                           placeholder="0.00"
                           @bind="form.Amount" />
                </div>
                <div class="form-group">
                    <label class="form-label">Date</label>
                    <input class="form-control"
                           type="date"
                           value="@form.Date.ToString("yyyy-MM-dd")"
                           @onchange="e => form.Date = DateOnly.Parse(e.Value!.ToString()!)" />
                </div>
                <div class="form-group">
                    <label class="form-label">Method</label>
                    <select class="form-control" @bind="form.Method">
                        <option value="Cash">Cash</option>
                        <option value="Bank Transfer">Bank Transfer</option>
                        <option value="Card">Card</option>
                        <option value="Other">Other</option>
                    </select>
                </div>
                <div class="form-group" style="margin-bottom:0">
                    <label class="form-label">Notes <span style="font-weight:400;color:var(--text-muted)">(optional)</span></label>
                    <input class="form-control"
                           type="text"
                           placeholder="e.g. January 2026 rent"
                           @bind="form.Notes" />
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="CloseModal">Cancel</button>
                <button class="btn btn-primary" @onclick="SavePayment" disabled="@saving">
                    @(saving ? "Saving…" : "Record Payment")
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }

    TenantDetailDto? tenant;
    PaymentDto[]?    payments;
    bool   loading        = true;
    bool   paymentsLoading = true;
    bool   showModal      = false;
    bool   saving         = false;
    string? pageError;
    string? modalError;

    PaymentForm form = new();

    int MonthsActive => tenant is null ? 0 :
        (DateOnly.FromDateTime(DateTime.Today).Year - tenant.LeaseStartDate.Year) * 12
        + DateOnly.FromDateTime(DateTime.Today).Month - tenant.LeaseStartDate.Month;

    string OutstandingClass => tenant?.OutstandingBalance switch
    {
        <= 0                                                     => "v-clear",
        var b when tenant?.MonthlyRent > 0 && b <= tenant.MonthlyRent => "v-warn",
        _                                                        => "v-bad"
    };

    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(LoadTenant(), LoadPayments());
    }

    async Task LoadTenant()
    {
        try   { tenant = await Api.GetTenantAsync(Id); }
        catch (Exception ex) { pageError = $"Failed to load tenant: {ex.Message}"; }
        finally { loading = false; }
    }

    async Task LoadPayments()
    {
        try   { payments = await Api.GetPaymentsAsync(Id); }
        catch { payments = []; }
        finally { paymentsLoading = false; }
    }

    void OpenPaymentModal()
    {
        form       = new();
        modalError = null;
        showModal  = true;
    }

    void CloseModal() => showModal = false;

    async Task SavePayment()
    {
        if (form.Amount <= 0) { modalError = "Amount must be greater than zero."; return; }

        modalError = null;
        saving     = true;
        try
        {
            await Api.CreatePaymentAsync(new CreatePaymentDto(
                Id, form.Amount, form.Date, form.Method, form.Notes?.Trim()));
            showModal = false;
            await Task.WhenAll(LoadTenant(), LoadPayments());
        }
        catch (Exception ex)
        {
            modalError = $"Could not save payment: {ex.Message}";
        }
        finally
        {
            saving = false;
        }
    }

    async Task HandleDeactivate()
    {
        try
        {
            await Api.DeactivateTenantAsync(Id);
            Nav.NavigateTo("/tenants");
        }
        catch (Exception ex)
        {
            pageError = $"Could not deactivate tenant: {ex.Message}";
        }
    }

    class PaymentForm
    {
        public decimal Amount { get; set; }
        public DateOnly Date  { get; set; } = DateOnly.FromDateTime(DateTime.Today);
        public string Method  { get; set; } = "Cash";
        public string? Notes  { get; set; }
    }
}
