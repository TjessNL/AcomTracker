@page "/expenses"
@inject AcomApiService Api
@inject IJSRuntime JS

<PageTitle>Expenses &amp; Damage — AcomTracker</PageTitle>

<div class="page-header">
    <div>
        <h1 class="page-title">Expenses &amp; Damage Reports</h1>
        <p class="page-subtitle">Log repair costs, damage events, and other property expenses</p>
    </div>
    <button class="btn btn-primary" @onclick="() => showForm = true">+ Report Expense</button>
</div>

@if (error is not null)
{
    <div class="alert alert-danger">@error</div>
}

<!-- Add Expense Form Overlay -->
@if (showForm)
{
    <div class="modal-overlay" @onclick="CloseForm">
        <div class="modal" style="max-width:520px" @onclick:stopPropagation>
            <div class="modal-header">
                <span class="modal-title">Report Expense / Damage</span>
                <button class="modal-close" @onclick="CloseForm">×</button>
            </div>
            <div class="modal-body">
                @if (formError is not null)
                {
                    <div class="alert alert-danger">@formError</div>
                }

                <div class="form-group">
                    <label class="form-label">
                        Description <span style="color:var(--danger)">*</span>
                    </label>
                    <textarea class="form-control"
                              rows="3"
                              placeholder="Describe the damage or expense in detail (e.g. Broken window in unit 3, replaced by contractor)"
                              @bind="form.Description"></textarea>
                    @if (showValidation && string.IsNullOrWhiteSpace(form.Description))
                    {
                        <div class="form-error">Description is required</div>
                    }
                </div>

                <div class="form-group">
                    <label class="form-label">Amount (€) <span style="color:var(--danger)">*</span></label>
                    <input class="form-control"
                           type="number" step="0.01" min="0.01"
                           placeholder="0.00"
                           @bind="form.Amount" />
                    @if (showValidation && form.Amount <= 0)
                    {
                        <div class="form-error">Amount must be greater than zero</div>
                    }
                </div>

                <div style="display:flex;gap:12px">
                    <div class="form-group" style="flex:1">
                        <label class="form-label">Date</label>
                        <input class="form-control"
                               type="date"
                               value="@form.Date.ToString("yyyy-MM-dd")"
                               @onchange="e => form.Date = DateOnly.Parse(e.Value!.ToString()!)" />
                    </div>
                    <div class="form-group" style="flex:1">
                        <label class="form-label">Category</label>
                        <select class="form-control" @bind="form.Category">
                            <option value="">— Select —</option>
                            <option>Repair</option>
                            <option>Maintenance</option>
                            <option>Damage</option>
                            <option>Cleaning</option>
                            <option>Legal</option>
                            <option>Utilities</option>
                            <option>Other</option>
                        </select>
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">Additional Notes <span style="color:var(--text-muted)">(optional)</span></label>
                    <input class="form-control"
                           type="text"
                           placeholder="e.g. Contractor invoice #45"
                           @bind="form.Notes" />
                </div>

                <div class="form-group" style="margin-bottom:0">
                    <label class="form-label">Photo Evidence <span style="color:var(--text-muted)">(optional)</span></label>
                    <div class="file-drop @(photoPreviewing ? "has-file" : "")">
                        <InputFile OnChange="OnPhotoSelected" accept="image/*" style="display:none" id="photo-input" />
                        <label for="photo-input" class="file-drop-label">
                            @if (photoPreviewing)
                            {
                                <div style="text-align:center">
                                    <img src="@photoPreviewUrl" alt="Preview" style="max-height:140px;border-radius:8px;margin-bottom:8px" />
                                    <div style="font-size:12px;color:var(--text-muted)">@photoFileName — click to change</div>
                                </div>
                            }
                            else
                            {
                                <div style="text-align:center;color:var(--text-muted)">
                                    <div style="font-size:28px;margin-bottom:4px">📷</div>
                                    <div style="font-size:13px">Click to attach a photo</div>
                                </div>
                            }
                        </label>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="CloseForm">Cancel</button>
                <button class="btn btn-primary" @onclick="Submit" disabled="@saving">
                    @(saving ? "Saving…" : "Submit Report")
                </button>
            </div>
        </div>
    </div>
}

<!-- Expense List -->
@if (loading)
{
    <div class="loader">
        <div class="spinner"></div>
        <p class="loader-text">Loading expenses...</p>
    </div>
}
else if (expenses is null || expenses.Length == 0)
{
    <div class="empty-state">
        <div class="empty-state-icon">🧾</div>
        <div class="empty-state-title">No expenses recorded</div>
        <div class="empty-state-desc">Use the button above to report a damage or expense</div>
    </div>
}
else
{
    <!-- Category filter bar -->
    <div class="toolbar" style="margin-bottom:20px">
        <div style="display:flex;gap:8px;flex-wrap:wrap">
            <button class="btn @(selectedCategory is null ? "btn-primary" : "btn-secondary") btn-sm"
                    @onclick="() => FilterCategory(null)">All</button>
            @foreach (var cat in categories)
            {
                <button class="btn @(selectedCategory == cat ? "btn-primary" : "btn-secondary") btn-sm"
                        @onclick="() => FilterCategory(cat)">@cat</button>
            }
        </div>
        <span style="font-size:13px;color:var(--text-muted)">
            Total: €@filteredExpenses.Sum(e => e.Amount).ToString("N0")
        </span>
    </div>

    <div class="expense-list">
        @foreach (var e in filteredExpenses)
        {
            <div class="expense-row">
                <div style="display:flex;align-items:center;gap:14px;flex:1">
                    <div class="expense-icon">
                        @CategoryIcon(e.Category)
                    </div>
                    <div style="flex:1">
                        <div class="expense-desc">@e.Description</div>
                        @if (e.Notes is { Length: > 0 })
                        {
                            <div class="expense-notes">@e.Notes</div>
                        }
                        <div class="expense-meta">
                            @e.Date.ToString("MMM d, yyyy")
                            @if (e.Category is { Length: > 0 })
                            {
                                <span class="badge badge-neutral" style="margin-left:8px">@e.Category</span>
                            }
                            @if (e.HasPhoto)
                            {
                                <span style="margin-left:8px;font-size:12px;color:var(--text-muted)">📷 Photo attached</span>
                            }
                        </div>
                    </div>
                </div>
                <div style="display:flex;align-items:center;gap:12px">
                    <span class="expense-amount">€@e.Amount.ToString("N0")</span>
                    @if (e.HasPhoto)
                    {
                        <a href="@(Api.GetPhotoUrl(e.ExpenseId))" target="_blank" class="btn btn-secondary btn-sm">Photo</a>
                    }
                    <button class="btn btn-danger-soft btn-sm" @onclick="() => DeleteExpense(e.ExpenseId)">×</button>
                </div>
            </div>
        }
    </div>
}

@code {
    ExpenseDto[]? expenses;
    string[]     categories     = [];
    string?      selectedCategory;
    bool         loading        = true;
    bool         showForm       = false;
    bool         saving         = false;
    bool         showValidation = false;
    string?      error;
    string?      formError;

    byte[]?  photoBytes;
    string?  photoMimeType;
    string?  photoFileName;
    string?  photoPreviewUrl;
    bool     photoPreviewing;

    IEnumerable<ExpenseDto> filteredExpenses =>
        expenses?.Where(e => selectedCategory is null ||
                             string.Equals(e.Category, selectedCategory, StringComparison.OrdinalIgnoreCase))
               ?? [];

    ExpenseForm form = new();

    protected override async Task OnInitializedAsync() => await Load();

    async Task Load()
    {
        loading = true;
        try
        {
            await Task.WhenAll(LoadExpenses(), LoadCategories());
        }
        finally { loading = false; }
    }

    async Task LoadExpenses()
    {
        expenses = await Api.GetExpensesAsync();
    }

    async Task LoadCategories()
    {
        categories = await Api.GetExpenseCategoriesAsync() ?? [];
    }

    void FilterCategory(string? cat)
    {
        selectedCategory = cat;
    }

    void CloseForm()
    {
        showForm       = false;
        showValidation = false;
        formError      = null;
        form           = new();
        photoBytes     = null;
        photoMimeType  = null;
        photoFileName  = null;
        photoPreviewUrl = null;
        photoPreviewing = false;
    }

    async Task OnPhotoSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file is null) return;

        var maxSize = 5 * 1024 * 1024; // 5 MB
        using var ms = new MemoryStream();
        await file.OpenReadStream(maxSize).CopyToAsync(ms);
        photoBytes     = ms.ToArray();
        photoMimeType  = file.ContentType;
        photoFileName  = file.Name;
        photoPreviewUrl = $"data:{file.ContentType};base64,{Convert.ToBase64String(photoBytes)}";
        photoPreviewing = true;
    }

    async Task Submit()
    {
        showValidation = true;
        if (string.IsNullOrWhiteSpace(form.Description) || form.Amount <= 0)
            return;

        saving    = true;
        formError = null;
        try
        {
            await Api.CreateExpenseAsync(
                form.Description, form.Amount, form.Date,
                NullIfEmpty(form.Category), NullIfEmpty(form.Notes),
                photoBytes, photoMimeType, photoFileName);

            CloseForm();
            await Load();
        }
        catch (Exception ex)
        {
            formError = $"Could not save: {ex.Message}";
        }
        finally { saving = false; }
    }

    async Task DeleteExpense(int id)
    {
        try
        {
            await Api.DeleteExpenseAsync(id);
            await Load();
        }
        catch (Exception ex)
        {
            error = $"Could not delete: {ex.Message}";
        }
    }

    static string CategoryIcon(string? cat) => cat switch
    {
        "Repair"      => "🔧",
        "Maintenance" => "🛠",
        "Damage"      => "⚠️",
        "Cleaning"    => "🧹",
        "Legal"       => "⚖️",
        "Utilities"   => "💡",
        _             => "📋"
    };

    static string? NullIfEmpty(string s) => string.IsNullOrWhiteSpace(s) ? null : s;

    class ExpenseForm
    {
        public string  Description { get; set; } = "";
        public decimal Amount      { get; set; }
        public DateOnly Date       { get; set; } = DateOnly.FromDateTime(DateTime.Today);
        public string  Category    { get; set; } = "";
        public string  Notes       { get; set; } = "";
    }
}
