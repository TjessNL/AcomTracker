@page "/analysis"
@inject AcomApiService Api
@inject IJSRuntime JS
@implements IAsyncDisposable

<PageTitle>Analysis — AcomTracker</PageTitle>

<div class="page-header">
    <div>
        <h1 class="page-title">Analysis</h1>
        <p class="page-subtitle">Visual overview of rent collection, balances, and expenses</p>
    </div>
</div>

@if (loading)
{
    <div class="loader">
        <div class="spinner"></div>
        <p class="loader-text">Loading data...</p>
    </div>
}
else if (error is not null)
{
    <div class="alert alert-danger">@error</div>
}
else
{
    <!-- Summary stats row -->
    <div class="stats-grid" style="margin-bottom:28px">
        <div class="stat-card">
            <div class="stat-label">Tenants</div>
            <div class="stat-value">@(tenants?.Length ?? 0)</div>
            <div class="stat-sublabel">active</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Total Collected</div>
            <div class="stat-value is-positive">€@totalPaid.ToString("N0")</div>
            <div class="stat-sublabel">all time</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Total Outstanding</div>
            <div class="stat-value @(totalOutstanding > 0 ? "is-danger" : "is-positive")">
                €@totalOutstanding.ToString("N0")
            </div>
            <div class="stat-sublabel">unpaid rent</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Total Expenses</div>
            <div class="stat-value is-danger">€@totalExpenses.ToString("N0")</div>
            <div class="stat-sublabel">@(expenses?.Length ?? 0) entries</div>
        </div>
    </div>

    <!-- Row 1: Outstanding per tenant + Collected vs Outstanding doughnut -->
    <div style="display:grid;grid-template-columns:1fr 380px;gap:20px;margin-bottom:20px">
        <div class="card">
            <div class="card-header">
                <span class="card-title">Outstanding Balance by Tenant</span>
            </div>
            <div class="card-body">
                <div style="height:300px">
                    <canvas id="chartOutstanding"></canvas>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <span class="card-title">Collected vs Outstanding</span>
            </div>
            <div class="card-body" style="display:flex;align-items:center;justify-content:center">
                <div style="height:280px;width:280px">
                    <canvas id="chartDonut"></canvas>
                </div>
            </div>
        </div>
    </div>

    <!-- Row 2: Expense breakdown by category -->
    @if (expenses is not null && expenses.Length > 0)
    {
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:20px">
            <div class="card">
                <div class="card-header">
                    <span class="card-title">Expenses by Category</span>
                </div>
                <div class="card-body">
                    <div style="height:260px">
                        <canvas id="chartExpenseCat"></canvas>
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="card-header">
                    <span class="card-title">Top Expenses</span>
                </div>
                <div class="card-body">
                    <div style="height:260px">
                        <canvas id="chartTopExpenses"></canvas>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Monthly rent collection bar -->
    <div class="card">
        <div class="card-header">
            <span class="card-title">Rent — Charged vs Paid per Tenant</span>
        </div>
        <div class="card-body">
            <div style="height:300px">
                <canvas id="chartRentComparison"></canvas>
            </div>
        </div>
    </div>
}

@code {
    TenantSummaryDto[]? tenants;
    ExpenseDto[]?       expenses;
    bool   loading = true;
    string? error;

    decimal totalPaid        => tenants?.Sum(t => t.TotalPaid)       ?? 0;
    decimal totalOutstanding => tenants?.Sum(t => Math.Max(t.OutstandingBalance, 0)) ?? 0;
    decimal totalExpenses    => expenses?.Sum(e => e.Amount)          ?? 0;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await Task.WhenAll(LoadTenants(), LoadExpenses());
        }
        catch (Exception ex)
        {
            error = $"Could not load data: {ex.Message}";
        }
        finally { loading = false; }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!loading && error is null)
            await RenderCharts();
    }

    async Task LoadTenants() => tenants = await Api.GetDashboardAsync();
    async Task LoadExpenses() => expenses = await Api.GetExpensesAsync();

    async Task RenderCharts()
    {
        if (tenants is null) return;

        // Bar: outstanding per tenant (only those with balance > 0)
        var withBalance = tenants.Where(t => t.OutstandingBalance > 0).ToList();
        await JS.InvokeVoidAsync("acomCharts.renderHorizontalBar",
            "chartOutstanding",
            withBalance.Select(t => t.Name).ToArray(),
            withBalance.Select(t => (double)t.OutstandingBalance).ToArray(),
            "#ef4444");

        // Doughnut: collected vs outstanding
        await JS.InvokeVoidAsync("acomCharts.renderDoughnut",
            "chartDonut",
            new[] { "Collected", "Outstanding" },
            new[] { (double)totalPaid, (double)totalOutstanding },
            new[] { "#22c55e", "#ef4444" });

        // Bar: charged vs paid per tenant
        await JS.InvokeVoidAsync("acomCharts.renderBar",
            "chartRentComparison",
            tenants.Select(t => t.Name).ToArray(),
            new[]
            {
                new { label = "Charged", data = tenants.Select(t => (double)t.TotalCharged).ToArray(),
                      backgroundColor = "#6366f1", borderRadius = 4 },
                new { label = "Paid",    data = tenants.Select(t => (double)t.TotalPaid).ToArray(),
                      backgroundColor = "#22c55e", borderRadius = 4 }
            });

        // Expense charts
        if (expenses is { Length: > 0 })
        {
            var byCat = expenses
                .GroupBy(e => e.Category ?? "Uncategorised")
                .Select(g => (Label: g.Key, Total: g.Sum(e => e.Amount)))
                .OrderByDescending(g => g.Total)
                .ToList();

            string[] catColors = ["#6366f1", "#f59e0b", "#ef4444", "#22c55e", "#3b82f6", "#8b5cf6", "#ec4899"];
            await JS.InvokeVoidAsync("acomCharts.renderDoughnut",
                "chartExpenseCat",
                byCat.Select(g => g.Label).ToArray(),
                byCat.Select(g => (double)g.Total).ToArray(),
                catColors.Take(byCat.Count).ToArray());

            var top = expenses.OrderByDescending(e => e.Amount).Take(8).ToList();
            await JS.InvokeVoidAsync("acomCharts.renderHorizontalBar",
                "chartTopExpenses",
                top.Select(e => e.Description.Length > 30 ? e.Description[..27] + "…" : e.Description).ToArray(),
                top.Select(e => (double)e.Amount).ToArray(),
                "#f59e0b");
        }
    }

    public async ValueTask DisposeAsync()
    {
        foreach (var id in new[] { "chartOutstanding", "chartDonut", "chartRentComparison", "chartExpenseCat", "chartTopExpenses" })
            await JS.InvokeVoidAsync("acomCharts.destroyChart", id);
    }
}
